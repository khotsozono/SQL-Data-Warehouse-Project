-------------------------------------------------------------- 
CREATE DATABASE DataWarehouse;
GO

USE DataWarehouse;
GO

---------------------------------------------------------------
-- Create Schemas (bronze, silver & gold)
---------------------------------------------------------------
CREATE SCHEMA bronze;
GO

